{
  "name": "openmeme-web",
  "account_id": "$CLOUDFLARE_ACCOUNT_ID",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-05-28",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets"
  },
  "routes": [
    { "pattern": "openmeme.io", "custom_domain": true }
  ],
  "observability": {
    "enabled": true
  }
}
