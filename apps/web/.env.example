# ============================================================
# OpenMeme Web — Cloudflare Workers Environment Variables
# Copy this file to .env.local for local development
# ============================================================

# Public vars (inlined at build time)
NEXT_PUBLIC_MEMES_API_URL=http://localhost:8080
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_key

# Server-side secrets (use `wrangler secret put`)
# MEMES_API_KEY=<set via wrangler secret>
# NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=<set via wrangler secret>

# Local dev only (ignored by git)
# CLOUDFLARE_ACCOUNT_ID=your_account_id
