# ── Web (apps/web) — Environment Variables ──────────────────
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

# Required at build time
NEXT_PUBLIC_MEMES_API_URL=https://api.openmeme.io
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=your-32-character-key-here

# Required at runtime (set as Cloudflare Worker secrets via wrangler secret put)
MEMES_API_KEY=your_read_only_api_key

# PostHog analytics (build-time, NEXT_PUBLIC_*)
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_key
NEXT_PUBLIC_POSTHOG_HOST=your_posthog_host

# ── Cloudflare (deploy-time) ────────────────────────────────
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
NEXT_TAG_CACHE_D1_ID=your_d1_database_id
