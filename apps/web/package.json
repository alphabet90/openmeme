{
  "name": "@openmeme/web",
  "version": "1.0.0",
  "private": true,
  "description": "OpenMeme — vanilla PHP + SQLite + jQuery site. Extreme-minimalist, /memes/* is the source of truth.",
  "scripts": {
    "build": "webpack --mode production",
    "dev": "webpack --mode development --watch",
    "clean": "rm -rf public/assets/app.js public/assets/app.css",
    "index": "php bin/build-index.php && php bin/build-search.php",
    "index:db": "php bin/build-index.php",
    "index:search": "php bin/build-search.php",
    "test": "php vendor/bin/phpunit",
    "serve": "php -S 0.0.0.0:8090 -t public public/index.php"
  },
  "dependencies": {
    "jquery": "^3.7.1"
  },
  "devDependencies": {
    "css-loader": "^7.1.2",
    "css-minimizer-webpack-plugin": "^7.0.0",
    "mini-css-extract-plugin": "^2.9.2",
    "terser-webpack-plugin": "^5.3.11",
    "webpack": "^5.97.1",
    "webpack-cli": "^5.1.4"
  }
}
