{
  "name": "@openmeme/design-system",
  "version": "1.0.0",
  "private": true,
  "description": "OpenMeme Design System — migrated from reddit.memes with Refero standards",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "style": "./dist/tokens.css",
  "files": [
    "dist/",
    "tokens/",
    "references/"
  ],
  "scripts": {
    "build": "tsc && npm run build-tokens",
    "build-tokens": "node scripts/build-tokens.js",
    "dev": "tsc --watch",
    "lint": "eslint src/**/*.ts",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "design-system",
    "openmeme",
    "tokens",
    "refero"
  ],
  "license": "Apache-2.0"
}
