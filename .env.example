# ============================================================
# OpenMeme — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# ── SCRAPER ──────────────────────────────────────────────────
# Subreddit to scrape
SUBREDDIT=argentina

# Paths
REPO_PATH=/path/to/repo
TMP_DIR=/tmp/memes
BLOOM_FILTER_FILE=data/processed.bloom

# AI Classifier: claude or codex
CLASSIFIER=claude
CLASSIFY_WORKERS=4

# Reddit API
REDDIT_USER_AGENT="OpenMemeBot/1.0 (by u/your_username)"
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
REDDIT_USERNAME=your_username
REDDIT_PASSWORD=your_password

# ── SCRIPTS ──────────────────────────────────────────────────
BATCH_SIZE=10
DRY_RUN=false
PER_POST=false
FROM_FILE=
POST_URL=

# ── SYNC ─────────────────────────────────────────────────────
SYNC_SUBREDDITS=argentina
SYNC_LIMIT=100
SYNC_BATCH_SIZE=10
SYNC_CLASSIFIER=claude
SYNC_CLASSIFY_WORKERS=4
SYNC_MIN_COMMENT_UPVOTES=0
SYNC_DRY_RUN=false
SYNC_TIME=sun00

# ── WEB ──────────────────────────────────────────────────────
OPENMEME_BASE_URL=https://openmeme.example.com

# ── MEILISEARCH (required for /search and /api/suggest) ─────
# Master key: used by docker-compose and key management only.
# Min 16 bytes — generate with: openssl rand -base64 24
MEILI_MASTER_KEY=change-me-min-16-bytes
# Set to "production" on the server (makes the master key mandatory)
MEILI_ENV=development
# URL the PHP app uses to reach Meilisearch
MEILI_URL=http://127.0.0.1:7700
# Admin key used by bin/build-search.php. Optional in dev (falls back
# to MEILI_MASTER_KEY). Print scoped keys with: php bin/meili-keys.php
MEILI_ADMIN_KEY=
# Search-only key used by the web runtime. Optional in dev (falls back
# to MEILI_MASTER_KEY). Use a scoped key in production.
MEILI_SEARCH_KEY=

# ── OPTIMIZE ─────────────────────────────────────────────────
OPTIMIZE_DRY_RUN=false
OPTIMIZE_RESIZE=false
