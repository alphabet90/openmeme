# ============================================================
# OpenMeme — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# ── SCRAPER ──────────────────────────────────────────────────
# Subreddit to scrape
SUBREDDIT=argentina

# Paths
REPO_PATH=/path/to/repo
TMP_DIR=/tmp/memes
BLOOM_FILTER_FILE=data/processed.bloom

# AI Classifier: claude or codex
CLASSIFIER=claude
CLASSIFY_WORKERS=4

# Reddit API
REDDIT_USER_AGENT="OpenMemeBot/1.0 (by u/your_username)"
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
REDDIT_USERNAME=your_username
REDDIT_PASSWORD=your_password

# ── API ──────────────────────────────────────────────────────
PORT=8080
DB_URL=jdbc:postgresql://localhost:5432/memesdb
DB_USER=memes
DB_PASSWORD=memes
REDIS_HOST=localhost
REDIS_PORT=6379

# ── SCRIPTS ──────────────────────────────────────────────────
BATCH_SIZE=10
DRY_RUN=false
PER_POST=false
FROM_FILE=
POST_URL=

# ── SYNC ─────────────────────────────────────────────────────
SYNC_SUBREDDITS=argentina
SYNC_LIMIT=100
SYNC_BATCH_SIZE=10
SYNC_CLASSIFIER=claude
SYNC_CLASSIFY_WORKERS=4
SYNC_MIN_COMMENT_UPVOTES=0
SYNC_DRY_RUN=false
SYNC_TIME=sun00

# ── WEB ──────────────────────────────────────────────────────
NEXT_PUBLIC_MEMES_API_URL=http://localhost:8080
MEMES_API_KEY=your_read_only_api_key
WEB_PORT=3000
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=your-32-character-key-here
REDIS_PASSWORD=

# ── OPTIMIZE ─────────────────────────────────────────────────
OPTIMIZE_DRY_RUN=false
OPTIMIZE_RESIZE=false
